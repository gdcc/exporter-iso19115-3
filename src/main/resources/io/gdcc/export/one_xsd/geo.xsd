<?xml version="1.0" encoding="UTF-8" ?>
<xs:schema 
	targetNamespace="http://geo.scholarsportal.info/ScholarsGeoPortalISO"
	xmlns="http://Scholars GeoPortalexportForVictoria/GeoPortal_Schema" 
	xmlns:sp-geo="http://geo.scholarsportal.info/ScholarsGeoPortalISO" 
	xmlns:xs="http://www.w3.org/2001/XMLSchema">
	<xs:complexType name="_ReferenceSystem" abstract="true">
	</xs:complexType>
	<xs:complexType name="_Citation" abstract="true">
	</xs:complexType>
	<xs:complexType name="_LineageInformation" abstract="true">
	</xs:complexType>
	<xs:complexType name="_SpatialRepresentation" abstract="true">
	</xs:complexType>
	<xs:complexType name="_ResourceDescription" abstract="true">
	</xs:complexType>
	<xs:complexType name="_Responsibility" abstract="true">
	</xs:complexType>
	<xs:complexType name="_Extent" abstract="true">
	</xs:complexType>
	<xs:complexType name="_OnlineResource" abstract="true">
	</xs:complexType>
	<xs:complexType name="_Distribution" abstract="true">
	</xs:complexType>
	<xs:complexType name="_Constraints" abstract="true">
	</xs:complexType>
	<xs:complexType name="_TypedDate" abstract="true">
	</xs:complexType>
	<xs:complexType name="CI_Organisation">
		<xs:annotation>
			<xs:documentation>
				information about the party if the party is an organisation
			</xs:documentation>
		</xs:annotation>
		<xs:complexContent>
			<xs:extension base="sp-geo:CI_Party">
			</xs:extension>
		</xs:complexContent>
	</xs:complexType>
	<xs:complexType name="CI_Series">
		<xs:annotation>
			<xs:documentation>
				information about the series, or aggregate resource, to which a resource belongs
			</xs:documentation>
		</xs:annotation>
		<xs:all>
			<xs:element name="name" type="sp-geo:CharacterString" minOccurs="0" maxOccurs="1">
			</xs:element>
		</xs:all>
	</xs:complexType>
	<xs:complexType name="CI_Address">
		<xs:annotation>
			<xs:documentation>
				location of the responsible individual or organisation
			</xs:documentation>
		</xs:annotation>
		<xs:all>
			<xs:element name="city" type="sp-geo:CharacterString" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="administrativeArea" type="sp-geo:CharacterString" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="country" type="sp-geo:CharacterString" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="electronicMailAddress" type="sp-geo:CharacterString" minOccurs="0" maxOccurs="1">
			</xs:element>
		</xs:all>
	</xs:complexType>
	<xs:complexType name="CI_OnlineResource">
		<xs:annotation>
			<xs:documentation>
				information about on-line sources from which the resource, specification, or community profile name and extended metadata elements can be obtained
			</xs:documentation>
		</xs:annotation>
		<xs:complexContent>
			<xs:extension base="sp-geo:_OnlineResource">
				<xs:all>
					<xs:element name="linkage" type="sp-geo:CharacterString" minOccurs="0" maxOccurs="1">
					</xs:element>
					<xs:element name="protocol" type="sp-geo:CharacterString" minOccurs="0" maxOccurs="1">
					</xs:element>
					<xs:element name="name" type="sp-geo:CharacterString" minOccurs="0" maxOccurs="1">
					</xs:element>
					<xs:element name="description" type="sp-geo:CharacterString" minOccurs="0" maxOccurs="1">
					</xs:element>
				</xs:all>
			</xs:extension>
		</xs:complexContent>
	</xs:complexType>
	<xs:complexType name="CI_Contact">
		<xs:annotation>
			<xs:documentation>
				information required to enable contact with the responsible person and/or organisation
			</xs:documentation>
		</xs:annotation>
		<xs:all>
			<xs:element name="address" type="sp-geo:CI_Address" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="onlineResource" type="sp-geo:CI_OnlineResource" minOccurs="0" maxOccurs="1">
			</xs:element>
		</xs:all>
	</xs:complexType>
	<xs:complexType name="CI_Party" abstract="true">
		<xs:annotation>
			<xs:documentation>
				information about the individual and/or organisation of the party
			</xs:documentation>
		</xs:annotation>
		<xs:all>
			<xs:element name="name" type="sp-geo:CharacterString" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="contactInfo" type="sp-geo:CI_Contact" minOccurs="0" maxOccurs="1">
			</xs:element>
		</xs:all>
	</xs:complexType>
	<xs:complexType name="CI_RoleCode">
		<xs:annotation>
			<xs:documentation>
				function performed by the responsible party
			</xs:documentation>
		</xs:annotation>
		<xs:all>
			<xs:element name="resourceProvider" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="custodian" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="owner" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="user" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="distributor" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="originator" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="pointOfContact" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="principalInvestigator" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="processor" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="publisher" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="author" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="sponsor" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="coAuthor" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="collaborator" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="editor" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="mediator" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="rightsHolder" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="contributor" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="funder" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="stakeholder" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
		</xs:all>
	</xs:complexType>
	<xs:complexType name="CI_Responsibility">
		<xs:annotation>
			<xs:documentation>
				information about the party and their role
			</xs:documentation>
		</xs:annotation>
		<xs:complexContent>
			<xs:extension base="sp-geo:_Responsibility">
				<xs:all>
					<xs:element name="role" type="sp-geo:CI_RoleCode" minOccurs="0" maxOccurs="1">
					</xs:element>
					<xs:element name="party" type="sp-geo:CI_Party" minOccurs="1" maxOccurs="unbounded">
					</xs:element>
				</xs:all>
			</xs:extension>
		</xs:complexContent>
	</xs:complexType>
	<xs:complexType name="CI_DateTypeCode">
		<xs:annotation>
			<xs:documentation>
				identification of when a given event occurred
			</xs:documentation>
		</xs:annotation>
		<xs:all>
			<xs:element name="creation" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="publication" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="revision" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="expiry" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="lastUpdate" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="lastRevision" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="nextUpdate" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="unavailable" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="inForce" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="adopted" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="deprecated" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="superseded" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="validityBegins" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="validityExpires" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="released" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="distribution" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
		</xs:all>
	</xs:complexType>
	<xs:complexType name="CI_Date">
		<xs:annotation>
			<xs:documentation>
				reference date and event used to describe it
			</xs:documentation>
		</xs:annotation>
		<xs:complexContent>
			<xs:extension base="sp-geo:_TypedDate">
				<xs:all>
					<xs:element name="date" type="sp-geo:DateTime" minOccurs="0" maxOccurs="1">
					</xs:element>
					<xs:element name="dateType" type="sp-geo:CI_DateTypeCode" minOccurs="0" maxOccurs="1">
					</xs:element>
				</xs:all>
			</xs:extension>
		</xs:complexContent>
	</xs:complexType>
	<xs:complexType name="CI_Citation">
		<xs:annotation>
			<xs:documentation>
				standardized resource reference
			</xs:documentation>
		</xs:annotation>
		<xs:complexContent>
			<xs:extension base="sp-geo:_Citation">
				<xs:all>
					<xs:element name="title" type="sp-geo:CharacterString" minOccurs="0" maxOccurs="1">
					</xs:element>
					<xs:element name="alternateTitle" type="sp-geo:DateTime" minOccurs="0" maxOccurs="1">
					</xs:element>
					<xs:element name="date" type="sp-geo:CI_Date" minOccurs="0" maxOccurs="1">
					</xs:element>
					<xs:element name="edition" type="sp-geo:CharacterString" minOccurs="0" maxOccurs="1">
					</xs:element>
					<xs:element name="editionDate" type="sp-geo:DateTime" minOccurs="0" maxOccurs="1">
					</xs:element>
					<xs:element name="identifier" type="sp-geo:MD_Identifier" minOccurs="0" maxOccurs="1">
					</xs:element>
					<xs:element name="citedResponsibleParty" type="sp-geo:CI_Responsibility" minOccurs="0" maxOccurs="1">
					</xs:element>
					<xs:element name="series" type="sp-geo:CI_Series" minOccurs="0" maxOccurs="1">
					</xs:element>
					<xs:element name="otherCitationDetails" type="sp-geo:CharacterString" minOccurs="0" maxOccurs="1">
					</xs:element>
					<xs:element name="onlineResource" type="sp-geo:CI_OnlineResource" minOccurs="0" maxOccurs="1">
						<xs:annotation>
							<xs:documentation>
								This should be URL of GeoPortal metadata record (the unique URL that leads directly to the dataset metadata)
							</xs:documentation>
						</xs:annotation>

					</xs:element>
				</xs:all>
			</xs:extension>
		</xs:complexContent>
	</xs:complexType>
	<xs:complexType name="MD_Identifier">
		<xs:annotation>
			<xs:documentation>
				value uniquely identifying an object within a namespace
			</xs:documentation>
		</xs:annotation>
		<xs:all>
			<xs:element name="code" type="sp-geo:CharacterString" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="codeSpace" type="sp-geo:CharacterString" minOccurs="0" maxOccurs="1">
			</xs:element>
		</xs:all>
	</xs:complexType>
	<xs:complexType name="MD_BrowseGraphic">
		<xs:annotation>
			<xs:documentation>
				graphic that provides an illustration of the dataset (should include a legend for the graphic, if applicable)
			</xs:documentation>
		</xs:annotation>
		<xs:all>
			<xs:element name="fileName" type="sp-geo:CharacterString" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="fileDescription" type="sp-geo:CharacterString" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="fileType" type="sp-geo:CharacterString" minOccurs="0" maxOccurs="1">
			</xs:element>
		</xs:all>
	</xs:complexType>
	<xs:complexType name="MD_ScopeCode">
		<xs:annotation>
			<xs:documentation>
				class of information to which the referencing entity applies
			</xs:documentation>
		</xs:annotation>
		<xs:all>
			<xs:element name="attribute" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="attributeType" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="collectionHardware" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="collectionSession" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="dataset" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="series" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="nonGeographicDataset" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="dimensionGroup" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="feature" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="featureType" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="propertyType" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="fieldSession" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="software" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="service" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="model" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="tile" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="metadata" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="initiative" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="sample" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="document" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="repository" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="aggregate" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="product" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="collection" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="coverage" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="application" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
		</xs:all>
	</xs:complexType>
	<xs:complexType name="MD_SpatialRepresentationTypeCode">
		<xs:annotation>
			<xs:documentation>
				method used to represent geographic information in the resource
			</xs:documentation>
		</xs:annotation>
		<xs:all>
			<xs:element name="vector" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="grid" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="textTable" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="tin" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="stereoModel" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="video" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
		</xs:all>
	</xs:complexType>
	<xs:complexType name="MD_RestrictionCode">
		<xs:annotation>
			<xs:documentation>
				limitation(s) placed upon the access or use of the data
			</xs:documentation>
		</xs:annotation>
		<xs:all>
			<xs:element name="copyright" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="patent" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="patentPending" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="trademark" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="licence" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="intellectualPropertyRights" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="restricted" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="otherRestrictions" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="unrestricted" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="licenceUnrestricted" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="licenceEndUser" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="licenceDistributor" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="private" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="statutory" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="confidential" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="sensitiveButUnclassified" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="in_confidence" type="Class" minOccurs="0" maxOccurs="1">
			</xs:element>
		</xs:all>
	</xs:complexType>
	<xs:complexType name="MD_LegalConstraints">
		<xs:annotation>
			<xs:documentation>
				restrictions and legal prerequisites for accessing and using the resource or metadata
			</xs:documentation>
		</xs:annotation>
		<xs:complexContent>
			<xs:extension base="sp-geo:MD_Constraints">
				<xs:all>
					<xs:element name="accessConstraints" type="sp-geo:MD_RestrictionCode" minOccurs="0" maxOccurs="1">
					</xs:element>
					<xs:element name="useConstraints" type="sp-geo:MD_RestrictionCode" minOccurs="0" maxOccurs="1">
					</xs:element>
					<xs:element name="otherConstraints" type="sp-geo:CharacterString" minOccurs="0" maxOccurs="1">
					</xs:element>
				</xs:all>
			</xs:extension>
		</xs:complexContent>
	</xs:complexType>
	<xs:complexType name="MD_Constraints">
		<xs:annotation>
			<xs:documentation>
				restrictions on the access and use of a resource or metadata
			</xs:documentation>
		</xs:annotation>
		<xs:complexContent>
			<xs:extension base="sp-geo:_Constraints">
				<xs:all>
					<xs:element name="useLimitation" type="sp-geo:CharacterString" minOccurs="0" maxOccurs="1">
					</xs:element>
					<xs:element name="reference" type="sp-geo:_Citation" minOccurs="0" maxOccurs="1">
					</xs:element>
				</xs:all>
			</xs:extension>
		</xs:complexContent>
	</xs:complexType>
	<xs:complexType name="MD_Medium">
		<xs:annotation>
			<xs:documentation>
				information about the media on which the resource can be distributed
			</xs:documentation>
		</xs:annotation>
		<xs:all>
			<xs:element name="name" type="sp-geo:_Citation" minOccurs="0" maxOccurs="1">
			</xs:element>
		</xs:all>
	</xs:complexType>
	<xs:complexType name="MD_Format">
		<xs:annotation>
			<xs:documentation>
				description of the computer language construct that specifies the representation of data objects in a record, file, message, storage device or transmission channel
			</xs:documentation>
		</xs:annotation>
		<xs:all>
			<xs:element name="medium" type="sp-geo:MD_Medium" minOccurs="0" maxOccurs="1">
			</xs:element>
		</xs:all>
	</xs:complexType>
	<xs:complexType name="MD_Distribution">
		<xs:annotation>
			<xs:documentation>
				information about the distributor of and options for obtaining the resource
			</xs:documentation>
		</xs:annotation>
		<xs:complexContent>
			<xs:extension base="sp-geo:_Distribution">
				<xs:all>
					<xs:element name="description" type="sp-geo:CharacterString" minOccurs="0" maxOccurs="1">
					</xs:element>
					<xs:element name="transferOptions" type="sp-geo:MD_DigitalTransferOptions" minOccurs="0" maxOccurs="unbounded">
					</xs:element>
				</xs:all>
			</xs:extension>
		</xs:complexContent>
	</xs:complexType>
	<xs:complexType name="MD_DigitalTransferOptions">
		<xs:annotation>
			<xs:documentation>
				technical means and media by which a resource is obtained from the distributor
			</xs:documentation>
		</xs:annotation>
		<xs:all>
			<xs:element name="onLine" type="sp-geo:_OnlineResource" minOccurs="0" maxOccurs="1">
			</xs:element>
			<xs:element name="distributionFormat" type="sp-geo:MD_Format" minOccurs="0" maxOccurs="1">
			</xs:element>
		</xs:all>
	</xs:complexType>
	<xs:complexType name="EX_GeographicBoundingBox">
		<xs:annotation>
			<xs:documentation>
				geographic position of the resource NOTE: This is only an approximate reference so specifying the coordinate reference system is unnecessary and need only be provided with a precision of up to two decimal places
			</xs:documentation>
		</xs:annotation>
		<xs:complexContent>
			<xs:extension base="sp-geo:EX_GeographicExtent">
				<xs:all>
					<xs:element name="westBoundLongitude" type="xs:decimal" minOccurs="0" maxOccurs="1">
					</xs:element>
